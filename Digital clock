import time
import sys
h=11
m=16
s=49
while True:
    sys.stdout.write("\r{:02d}:{:02d}:{:02d}".format(h,m,s))
    sys.stdout.flush()
    time.sleep(2)
    
    s=s+1
    if s==60:
        s=0
        m=m+1
    if m==60:
        m=0
        s=0
        h=h+1
        h=13
        s=0
        m=0
        h=0
